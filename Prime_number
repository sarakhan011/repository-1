import math

num = int (input("Enter a number = "))
if num < 2 :
 print("Its not a prime number")

else :
  i = 2
  prime = True

while i <= math.isqrt(num):
   if num % i == 0:
      prime = False
      break
   i += 1

if prime :
   print(f"{num} is a prime number.")
else:
   print(f"{num} is not a prime number")
 