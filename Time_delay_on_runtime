import time
def print_delay():
    delays = [
        "Your Files are currently loading",
        "Please wait a moment."]
    
    title = " loading !"
    for char in title:
      print(char, end='', flush=True)
      time.sleep(0.1)   
    print() 

    for line in delays:
      char_delay = 0.1
      for char in line:
            print(char, end='', flush=True)
            time.sleep(char_delay)
      print()  
      time.sleep(0.1)
print_delay()
